theme = dark:Bluloco Dark,light:Bluloco Light

font-family = ""
font-family = Lilex

font-style = Regular
font-style-bold = Bold
font-style-italic = Oblique
font-style-bold-italic = Bold Oblique

font-synthetic-style = no-bold,no-bold-italic,no-italic
font-size = 15.0
font-thicken = false
font-thicken-strength = 0

window-padding-x = 0
window-padding-y = 0
window-height = 40
window-width = 120
window-colorspace = display-p3
window-save-state = never

adjust-cell-height = 22%

shell-integration-features = cursor,sudo,title

macos-titlebar-style = tabs
macos-option-as-alt = false
