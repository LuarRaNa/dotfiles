{
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "One Dark"
  },

  "restore_on_startup": "empty_tab",
  "auto_update": false,
  "vim_mode": true,
  "format_on_save": "off",

  "tab_bar": {
    "show": false
  },

  "gutter": {
    "line_numbers": true,
    "min_line_number_digits": 6
  },

  "scrollbar": {
    "show": "always"
  },

  "sticky_scroll": {
    "enabled": true
  },

  "file_finder": {
    "file_icons": true,
    "modal_max_width": "large"
  },

  "ui_font_size": 15,
  "ui_font_family": "C0D3U1",
  "buffer_font_size": 13,
  "buffer_font_family": "C0D3",
  "agent_buffer_font_size": 13,
  "buffer_line_height": "comfortable",
  "soft_wrap": "bounded",
  "preferred_line_length": 80,
  "wrap_guides": [80, 100, 120],
  "show_wrap_guides": true,
  "terminal": {
    "line_height": "comfortable"
  },

  "indent_guides": {
    "enabled": true,
    "coloring": "fixed"
  },

  "vim": {
    "use_system_clipboard": "always"
  },

  "agent": {
    "show_turn_stats": true
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry"
    },
    "codex-acp": {
      "type": "registry"
    }
  }
}
